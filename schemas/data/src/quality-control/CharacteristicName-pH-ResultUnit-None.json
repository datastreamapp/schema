{
  "$id": "https://datastream.org/schema/data/quality-control/CharacteristicName-pH-ResultUnit-None.json",
  "title": "CharacteristicName-pH-ResultUnit-None",
  "description": "Characteristics that require None as unit.",
  "errorMessage": "qc-CharacteristicName-pH-ResultUnit-None",
  "if": {
    "type": "object",
    "unevaluatedProperties": true,
    "properties": {
      "CharacteristicName": {
        "enum": ["pH", "pH, lab", "pH, saturated", "Langelier Saturation Index"]
      },
      "ResultValue": true
    },
    "required": ["CharacteristicName", "ResultValue"]
  },
  "then": {
    "type": "object",
    "unevaluatedProperties": true,
    "properties": {
      "ResultUnit": {
        "enum": ["None"]
      }
    },
    "required": ["ResultUnit"]
  }
}
